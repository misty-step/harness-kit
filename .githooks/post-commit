#!/usr/bin/env bash
# Re-link skills/agents after commit when skill content changes.
# Covers the "create new skill, commit, it should appear" case.
# Bootstrap is fast (<1s) and idempotent.

bootstrap_relevant_changed() {
  git diff --name-only HEAD~1 HEAD 2>/dev/null |
    grep -q '^\(skills/\|agents/\|harnesses/\|\.githooks/\|bootstrap\.sh$\)'
}

bootstrap_relevant_changed || exit 0

echo "[post-commit] Harness Kit harness content changed — re-linking"
./bootstrap.sh
